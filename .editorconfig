# EditorConfig — formatação mecânica do RedeCrystal.
# Padrão observado no repositório. Ver docs/CODING_STANDARDS.md para o restante.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

# Java
[*.java]
indent_size = 4

# YAML / config (2 espaços por convenção do formato)
[*.{yml,yaml}]
indent_size = 2

# XML (poms)
[*.xml]
indent_size = 4

# Markdown — não cortar trailing whitespace (dois espaços = quebra de linha)
[*.md]
trim_trailing_whitespace = false

# Scripts de shell
[*.sh]
indent_size = 2

# Makefile exige tabs reais
[Makefile]
indent_style = tab
