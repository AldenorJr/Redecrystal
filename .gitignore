# Maven
target/
*.jar
!.mvn/wrapper/maven-wrapper.jar
.mvn/timing.properties

# Third-party server plugins are committed so the stack is self-contained.
!EXTERNAL_PLUGINS/
!EXTERNAL_PLUGINS/*.jar

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.classpath
.project

# Env / secrets
.env
*.local
# Active deployment config (copied from configuration/*.example); examples are kept.
configuration/environment
configuration/environment.local

# Logs
*.log
logs/

# Minecraft server runtime artifacts (worlds/plugins are mounted, not committed)
servers/**/cache/
servers/**/logs/
servers/**/*.jar
world/**/data/
world/**/region/

# OS
.DS_Store
Thumbs.db
