# ──────────────────────────────────────────────────────────────────────────
# RedeCrystal — published host ports (docker-compose interpolation layer).
# Copy to `.env`:  cp .env.example .env
#
# This file ONLY controls the host-side port mappings (the `${VAR}` values in
# docker-compose.yml). The container / deployment configuration (DB creds,
# tokens, hosts, LuckPerms, etc.) lives in configuration/environment — see
# configuration/environment.release.example and .production.example.
# ──────────────────────────────────────────────────────────────────────────

POSTGRES_PORT=55432       # host port → postgres:5432
REDIS_PORT=6379           # host port → redis:6379
KAFKA_UI_PORT=8085        # Kafka UI
EUREKA_PORT=8761          # Eureka dashboard
GATEWAY_PORT=8080         # API Gateway (only published backend port)
MC_PORT=25565             # Velocity proxy (players connect here)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Used only by the postgres healthcheck interpolation; keep in sync with
# configuration/environment if you change the DB user/name.
POSTGRES_USER=crystal
POSTGRES_DB=redecrystal
