# ──────────────────────────────────────────────────────────────────────────
# RedeCrystal — bootstrap environment.
# Copy to `.env` (`cp .env.example .env`) before running `docker compose up -d`.
# These are the ONLY values read from the environment. Everything else
# (motd, maxPlayers, maintenance, feature flags) is served by the Config Service.
# ──────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ──
# POSTGRES_DB is the bootstrap/maintenance DB; per-service databases (core_db, …)
# are created by infra/postgres/init-databases.sql on first volume init.
POSTGRES_DB=redecrystal
POSTGRES_USER=crystal
POSTGRES_PASSWORD=crystal
POSTGRES_PORT=55432

# ── Redis ──
REDIS_PORT=6379

# ── Kafka ──
# Internal (containers): kafka:9092   |   Host (your machine): localhost:29092
KAFKA_INTERNAL_BROKERS=kafka:9092
KAFKA_HOST_BROKERS=localhost:29092
KAFKA_UI_PORT=8085

# ── Backend microservices ──
EUREKA_PORT=8761          # Eureka dashboard / registry
GATEWAY_PORT=8080         # API Gateway — the only published backend entry point

# ── Authentication (enforced ONLY at the API Gateway) ──
# Static service token presented by every plugin/server as a Bearer token.
# Generate a strong value for real deployments.
BACKEND_SERVICE_TOKEN=change-me-dev-service-token
